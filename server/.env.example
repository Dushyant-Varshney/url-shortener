# Server Port
PORT=5001

# MongoDB Connection String
CONNECTION_STRING=mongodb://localhost:27017/url_shortener

# JWT Secret (set a strong value in production)
JWT_SECRET=replace-with-strong-secret

# Public backend URL used for short links and QR generation
# Example (Render): https://your-backend.onrender.com
BASE_URL=http://localhost:5001

# Allowed frontend origins (comma-separated)
# Example: https://your-frontend.vercel.app,https://www.yourdomain.com
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional Redis connection
# Use REDIS_URL or REDIS_HOST/REDIS_PORT
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Runtime mode
NODE_ENV=development